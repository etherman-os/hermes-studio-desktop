{
  "identifier": "preview",
  "description": "Reduced permissions for isolated preview windows",
  "windows": ["preview"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-set-title",
    "core:window:allow-is-visible"
  ]
}
